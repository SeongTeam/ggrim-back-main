{
    "editor.codeActionsOnSave" : {
        "source.fixAll.eslint": "never"
    },
	"eslint.workingDirectories": ["./"],
	"eslint.validate": ["typescript"],
    "prettier.enable": true,
	"editor.defaultFormatter": "esbenp.prettier-vscode",

	"prettier.requireConfig": true,
	"[typescript]": {
		"editor.formatOnSave": true,
		"editor.defaultFormatter": "esbenp.prettier-vscode"
	},
	"[javascript]": {
		"editor.formatOnSave": true,
		"editor.defaultFormatter": "esbenp.prettier-vscode"
	},
	"[markdown]": {
		"editor.unicodeHighlight.ambiguousCharacters": false,
		"editor.unicodeHighlight.invisibleCharacters": false,
		"diffEditor.ignoreTrimWhitespace": false,
		"editor.wordWrap": "on",
		"editor.quickSuggestions": {
			"comments": "off",
			"strings": "off",
			"other": "off"
		},
		"cSpell.fixSpellingWithRenameProvider": true,
		"cSpell.advanced.feature.useReferenceProviderWithRename": true,
		"cSpell.advanced.feature.useReferenceProviderRemove": "/^#+\\s/",
		"editor.formatOnSave": true,
		"editor.defaultFormatter": "esbenp.prettier-vscode"
	},
	"[handlebars]": {
		"editor.suggest.insertMode": "replace",
		"editor.formatOnSave": true,
		"editor.defaultFormatter": "esbenp.prettier-vscode"
	},
    
    "cSpell.language": "en",
    "cSpell.enabledFileTypes": ["typescript", "javascript", "python","markdown","plaintext"],
    "cSpell.words": [
        "completition",
        "distractor",
        "myCustomWord",
        "NestJS",
        "serie",
        "TypeScript"
    ],
    "cSpell.ignorePaths": ["node_modules/**", "**/*.json"],
    "cSpell.ignoreRegExpList": [
        "/^import /",                     // import로 시작하는 구문을 무시
        "/from\\s+['\"](.+)['\"]/i"       // from 절 뒤의 경로도 무시
      ],
    "cSpell.enabled": true,  // Enable the spell checker

	"jestrunner.jestCommand": "npx jest",
	// "jestrunner.debugOptions": {
	// 	"args" : ["--inspect-brk", 
	// 		"-r", "tsconfig-paths/register" ,
	// 		"-r" ,"ts-node/register", 
	// 		"node_modules/.bin/jest", 
	// 		"--runInBand"]
	// },

	"jestrunner.configPath": {
		"**/*.int-spec.ts": "test/integration/jest-integration.json",
		"**/*.e2e-spec.ts": "test/e2e/jest-e2e.json"
	},
	"jestrunner.codeLensSelector" : "**/*.{test,spec,e2e-spec,int-spec}.{js,jsx,ts,tsx}"

}