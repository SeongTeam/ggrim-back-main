{
  "setupFiles" : ["./setEnvVars.js"],
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": [".int-spec.ts$"],
  "transform": {
    "^.+\\.(t|j)s?$": ["ts-jest"]
  },
  "transformIgnorePatterns": [
    "node_modules/(?!@faker-js/faker)"
  ],
  "maxWorkers" : 1
}
